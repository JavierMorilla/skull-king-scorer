{
  "name": "react-example",
  "private": true,
  "version": "1.0.5",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:build:debug": "node scripts/build-apk.js",
    "android:build:release": "npm run android:sync && cd android && gradlew assembleRelease",
    "android:assets": "npx capacitor-assets generate --android"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^8.0.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/status-bar": "^8.0.2",
    "@capgo/capacitor-navigation-bar": "^8.1.3",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "lucide-react": "^0.546.0",
    "material-symbols": "^0.44.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
